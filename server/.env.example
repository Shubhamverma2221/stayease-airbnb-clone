PORT=5000
NODE_ENV=development
MONGO_URI=mongodb://localhost:27017/airbnb_clone
JWT_SECRET=your_jwt_secret_key_here
CLIENT_URL=http://localhost:5173

# Cloudinary credentials (optional - local file storage is default fallback)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Razorpay credentials (optional - mock payments is default fallback)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Stripe credentials (optional)
STRIPE_SECRET_KEY=your_stripe_secret_key

# Nodemailer SMTP credentials (optional - prints email to console as default fallback)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_EMAIL=your_smtp_username
SMTP_PASSWORD=your_smtp_password
FROM_NAME=Airbnb Clone Support
FROM_EMAIL=no-reply@airbnbclone.com
